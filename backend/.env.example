# --- App Settings ---
APP_TITLE="Economity API"
APP_DESCRIPTION="Backend Core MVP para el Hackathon"
APP_VERSION="1.0.0"

# --- Database Settings ---
# URL de conexión para el contenedor de PostgreSQL local (Podman/Docker)
DATABASE_URL="postgresql://economity_admin:economity_password@localhost:5432/economity_dev"

# --- Vector Database Settings ---
# URL de conexión para ChromaDB local
CHROMA_URL="http://localhost:8001"

# --- Authentication (Clerk) ---
# Opción A (recomendada): URL JWKS de Clerk para RS256 (sin copiar claves manualmente)
# Encuéntrala en: Clerk Dashboard > API Keys > JWKS URL
# Formato: https://<tu-clerk-domain>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL="https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json"
PUBLIC_CLERK_PUBLISHABLE_KEY="tu_clave_publica_aqui"
CLERK_SECRET_KEY="tu_clave_secreta_aqui"

# Opción B: Clave simétrica (solo si configuraste Clerk para HS256)
# JWT_SECRET_KEY="tu_clave_secreta_aqui"

# --- LLM API Keys ---
OPENAI_API_KEY="tu_clave_secreta_aqui"
DEEPSEEK_API_KEY="tu_clave_secreta_aqui"
CLAUDECODE_API_KEY="tu_clave_secreta_aqui"