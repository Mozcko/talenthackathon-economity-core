---
import FriendList from '../React/Social/FriendList';
---
<div class="bg-surface-container-low min-h-screen p-10 font-body">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-10">
        <h1 class="text-4xl font-display font-bold text-primary tracking-tight">Friends</h1>
        
        <!-- Make Friends Dropdown Container -->
        <div class="relative">
            <button 
                id="make-friends-btn"
                class="p-3 rounded-full bg-surface-container-lowest border border-outline-variant text-secondary transition-all duration-300 hover:scale-105 hover:shadow-[0_0_20px_var(--color-secondary-fixed-dim)]"
                title="Make Friends"
            >
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                    <line x1="19" y1="8" x2="19" y2="14"></line>
                    <line x1="22" y1="11" x2="16" y2="11"></line>
                </svg>
            </button>

            <!-- Dropdown Menu -->
            <div id="friends-dropdown" class="hidden absolute right-0 mt-4 w-72 card-base !p-6 shadow-ambient z-50 animate-in fade-in slide-in-from-top-2 duration-200">
                <p class="text-xs font-bold uppercase tracking-widest text-on-surface/40 mb-3">Your Unique Code</p>
                <div class="flex items-center gap-2 mb-6 bg-surface-container-low p-3 rounded-lg border border-outline-variant/30">
                    <code class="flex-1 font-mono font-bold text-secondary">ECON-9921-X</code>
                    <button id="copy-code" class="p-1 hover:text-secondary transition-colors" title="Copy to clipboard">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                    </button>
                </div>

                <p class="text-xs font-bold uppercase tracking-widest text-on-surface/40 mb-3">Add Friend</p>
                <div class="flex gap-2">
                    <input 
                        type="text" 
                        placeholder="Friend code goes here" 
                        class="input-field !py-2 !text-sm border border-outline-variant/30"
                    />
                    <button class="bg-secondary text-white p-2 rounded-lg hover:opacity-90 transition-opacity">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content Layout (60 - 40) -->
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-10">
        
        <!-- Left Side (60%): Friends List and Recent Activity -->
        <div class="lg:col-span-6 space-y-10">
            <!-- React Component: Friends List -->
            <section>
                <div class="flex items-center justify-between mb-6">
                    <h2 class="text-2xl font-display font-bold text-on-surface">Mis Amigos</h2>
                    <span class="text-sm font-medium text-on-surface/40">4 amigos en línea</span>
                </div>
                <FriendList client:load />
            </section>

            <!-- Placeholder: Recent Achievements -->
            <section>
                <h2 class="text-2xl font-display font-bold text-on-surface mb-6">Actividad Reciente</h2>
                <div class="space-y-4">
                    <!-- Achievement Placeholder 1 -->
                    <div class="flex items-center gap-4 p-5 bg-momentum-glow rounded-2xl border border-secondary/10">
                        <div class="w-12 h-12 rounded-xl bg-secondary/20 flex items-center justify-center text-secondary">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path><path d="M4 22h16"></path><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"></path><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"></path><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path></svg>
                        </div>
                        <div class="flex-1">
                            <p class="text-sm text-on-surface/60"><span class="font-bold text-on-surface">Alex Rivers</span> completó el reto de ahorro</p>
                            <h4 class="font-bold text-on-surface">Inversionista Maestro</h4>
                        </div>
                        <span class="text-xs font-medium text-on-surface/30 italic">Hace 2h</span>
                    </div>
                    <!-- Achievement Placeholder 2 -->
                    <div class="flex items-center gap-4 p-5 bg-surface-container-lowest rounded-2xl border border-outline-variant/30">
                        <div class="w-12 h-12 rounded-xl bg-primary/5 flex items-center justify-center text-primary/40">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"></path></svg>
                        </div>
                        <div class="flex-1">
                            <p class="text-sm text-on-surface/60"><span class="font-bold text-on-surface">Sam Chen</span> alcanzó el nivel 8</p>
                            <h4 class="font-bold text-on-surface">Crecimiento Constante</h4>
                        </div>
                        <span class="text-xs font-medium text-on-surface/30 italic">Hace 5h</span>
                    </div>
                </div>
            </section>
        </div>

        <!-- Right Side (40%): User Achievements -->
        <div class="lg:col-span-4">
            <div class="card-base sticky top-28 border border-outline-variant/30 shadow-ambient">
                <div class="flex items-center gap-3 mb-8">
                    <div class="p-2 bg-secondary/10 rounded-lg text-secondary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"></circle><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline></svg>
                    </div>
                    <h2 class="text-xl font-display font-bold text-primary">Tus Logros</h2>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <!-- Achievement Card 1 -->
                    <div class="bg-surface-container-low p-4 rounded-xl text-center border border-outline-variant/20">
                        <div class="text-3xl mb-2">🛡️</div>
                        <p class="text-[10px] font-bold uppercase tracking-tighter text-on-surface/40">Resiliencia</p>
                        <h5 class="text-sm font-bold text-on-surface">Fondo de Emergencia</h5>
                    </div>
                    <!-- Achievement Card 2 -->
                    <div class="bg-surface-container-low p-4 rounded-xl text-center border border-outline-variant/20">
                        <div class="text-3xl mb-2">📈</div>
                        <p class="text-[10px] font-bold uppercase tracking-tighter text-on-surface/40">Patrimonio</p>
                        <h5 class="text-sm font-bold text-on-surface">Primer Inversión</h5>
                    </div>
                    <!-- Achievement Card 3 (Locked) -->
                    <div class="bg-surface-container-low/50 p-4 rounded-xl text-center border border-dashed border-outline-variant/40 opacity-50 grayscale">
                        <div class="text-3xl mb-2">🔒</div>
                        <p class="text-[10px] font-bold uppercase tracking-tighter text-on-surface/40">Bloqueado</p>
                        <h5 class="text-sm font-bold text-on-surface">Maestro del Cashflow</h5>
                    </div>
                    <!-- Achievement Card 4 (Locked) -->
                    <div class="bg-surface-container-low/50 p-4 rounded-xl text-center border border-dashed border-outline-variant/40 opacity-50 grayscale">
                        <div class="text-3xl mb-2">🔒</div>
                        <p class="text-[10px] font-bold uppercase tracking-tighter text-on-surface/40">Bloqueado</p>
                        <h5 class="text-sm font-bold text-on-surface">Héroe del Retiro</h5>
                    </div>
                </div>
                
                <button class="btn-tertiary w-full mt-8 !text-sm">Ver todos los logros</button>
            </div>
        </div>
    </div>
</div>

<script>
    const btn = document.getElementById('make-friends-btn');
    const dropdown = document.getElementById('friends-dropdown');
    const copyBtn = document.getElementById('copy-code');

    // Toggle dropdown
    btn?.addEventListener('click', (e) => {
        e.stopPropagation();
        dropdown?.classList.toggle('hidden');
    });

    // Copy functionality
    copyBtn?.addEventListener('click', () => {
        navigator.clipboard.writeText('ECON-9921-X');
        alert('Código copiado al portapapeles');
    });

    // Close dropdown on click outside
    document.addEventListener('click', () => dropdown?.classList.add('hidden'));
    dropdown?.addEventListener('click', (e) => e.stopPropagation());
</script>