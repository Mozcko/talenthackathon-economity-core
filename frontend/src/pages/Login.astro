---
import LoginLayout from '../layouts/LoginLayout.astro'
import { Show } from '@clerk/astro/components'
---

<LoginLayout title="Clerk + Astro">
  <Show when="signed-out">
    <p>Sign in to try Clerk out!</p>
  </Show>
  <Show when="signed-in">
    <p>You are signed in!</p>
  </Show>
</LoginLayout>