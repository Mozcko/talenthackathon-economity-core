---

import Layout from "../layouts/Layout.astro"
import Sidebar from "../components/Astro/Sidebar.astro"
import Transaction from "../components/Astro/Transaction.astro"
import Dashboard from "../components/Astro/Dashboard.astro"
import Insights from "../components/Astro/Insights.astro"
import Chat from "../components/Astro/Chat.astro"
import Vault from "../components/Astro/Vault.astro"
import Community from "../components/Astro/Social.astro"
import Metas from "../components/Astro/Metas.astro"
import Logros from "../components/Astro/Logros.astro"

// Get the current tab from the URL, defaulting to 'dashboard'
const currentTab = Astro.url.searchParams.get('tab') || 'dashboard';
---
<Layout title="Economity Dashboard">
	<div class="flex h-[calc(100vh-80px)] overflow-hidden">
		<Sidebar currentTab={currentTab} />
		<main class="flex-1 flex flex-col min-h-0 overflow-hidden w-full">
			{currentTab === 'dashboard' && <Dashboard />}
			{currentTab === 'transactions' && <Transaction />}
			{currentTab === 'insights' && <Insights />}
			{currentTab === 'vault' && <Vault />}
			{currentTab === 'metas' && <Metas />}
			{currentTab === 'logros' && <Logros />}
			{currentTab === 'chat' && <Chat />}
			{currentTab === 'community' && <Community />}
		</main>
	</div>
</Layout>

